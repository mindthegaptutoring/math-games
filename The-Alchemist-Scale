    exp:'✓  16 − 4 = 12. 12 ÷ 2 = 6. Each circle weighs 6. The second panel lights up!'
  },
  // ── 16 SHAPE MC  3 circles + 2 squares = 27, square=3
  { type:'mc', floor:'Floor Sixteen', name:'The Cipher Gallery III',
    story:'A third scale, and this one holds more shapes. The card reads: "Each 🟧 weighs 3." Three circles and two squares sit in the left pan. 27 sits in the right.',
    lp:'🔵🔵🔵 + 🟧🟧', rp:'27',
    q:'Each 🟧 weighs 3. Deal with both squares first, then divide among the circles. What does each 🔵 weigh?',
    ans:['5','6','7','8'], cor:2,
    exp:'✓  2 × 3 = 6. 27 − 6 = 21. 21 ÷ 3 = 7. Each circle weighs 7. Three panels lit — one more to go!'
  },
  // ── 17 SHAPE TYPED  5 circles + 2 squares = 36, square=3
  { type:'typed', floor:'Floor Seventeen', name:'The Cipher Gallery IV',
    story:'The fourth scale. This time, no choices — you must work it out yourself and type the answer. The card reads: "Each 🟧 weighs 3." Five circles and two squares sit in the left pan. 36 in the right.',
    lp:'5🔵 + 2🟧', rp:'36',
    q:'Each 🟧 weighs 3. Subtract both squares first, then divide. What does each 🔵 weigh?',
    ca:'6',
    exp:'✓  2 × 3 = 6. 36 − 6 = 30. 30 ÷ 5 = 6. Each circle weighs 6. The fourth panel glows!'
  },
  // ── 18 SHAPE TYPED  boss shape: 4 circles + 3 squares = 35, square=5
  { type:'typed', floor:'Floor Eighteen', name:'The Cipher Gallery — Final Panel',
    story:'The last scale in the gallery. Hardest yet. The card reads: "Each 🟧 weighs 5." Four circles and three squares are in the left pan. 35 in the right. The alchemist watches carefully.',
    lp:'4🔵 + 3🟧', rp:'35',
    q:'Each 🟧 weighs 5. Three steps: find the total square weight, subtract it, then divide. What does each 🔵 weigh?',
    ca:'5',
    exp:'✓  3 × 5 = 15. 35 − 15 = 20. 20 ÷ 4 = 5. Each circle weighs 5. All panels light up — the gallery is complete!'
  },

  // ── TRANSITION C (two-step level-up) fires here (after index 17, before index 18) ──

  // ── 19 MC n  two-step: 2n+4=18
  { type:'mc', floor:'Floor Nineteen', name:'The Twin-Lock Room',
    story:'Two locks, not one. The scale shows two operations at once — n is multiplied, then a number is added. Undo them in order: deal with the addition first, then the multiplication.',
    lp:'2×n + 4', rp:'18',
    q:'Subtract 4 from both sides, then divide. What is n?',
    ans:['5','6','7','8'], cor:2,
    exp:'✓  18 − 4 = 14. 14 ÷ 2 = 7. n = 7. Both locks click open at once!'
  },
  // ── 20 MC n  two-step: 3n−3=24
  { type:'mc', floor:'Floor Twenty', name:'The Ember Room',
    story:'Glowing embers fill a stone furnace that heats the room from below. The scale has a twist — n is multiplied by 3, then 3 is subtracted. Add back first, then divide.',
    lp:'3×n − 3', rp:'24',
    q:'Add 3 to both sides first, then divide. What is n?',
    ans:['7','8','9','10'], cor:2,
    exp:'✓  24 + 3 = 27. 27 ÷ 3 = 9. n = 9. The furnace dims — the path is clear!'
  },
  // ── 21 TYPED n  two-step: 4n+8=32
  { type:'typed', floor:'Floor Twenty-One', name:'The Copper Garden',
    story:'Dozens of copper pipes wind through this room like jungle vines, dripping softly. Four groups of n, plus 8 more, must balance 32.',
    lp:'4×n + 8', rp:'32',
    q:'What is n? Subtract 8 first, then divide by 4.',
    ca:'6',
    exp:'✓  32 − 8 = 24. 24 ÷ 4 = 6. n = 6. The pipes hum in harmony!'
  },
  // ── 22 MC n  two-step: 5n−5=45
  { type:'mc', floor:'Floor Twenty-Two', name:'The Hourglass Hall',
    story:'Hundreds of hourglasses hang from the ceiling, all draining in silence. Five groups of n, minus 5, must balance 45.',
    lp:'5×n − 5', rp:'45',
    q:'Add 5 to both sides, then divide by 5. What is n?',
    ans:['8','9','10','11'], cor:2,
    exp:'✓  45 + 5 = 50. 50 ÷ 5 = 10. n = 10. All the hourglasses flip at once — extraordinary!'
  },
  // ── 23 TYPED n  boss: proportion n:20=3:5
  { type:'typed', floor:'Floor Twenty-Three — The Summit', name:'The Grand Atelier',
    story:'The very top of the tower. Through great windows the jungle stretches to every horizon, fireflies drifting below like fallen stars. The Grand Alchemical Scale stands before you — the final seal. Left pan: n : 20. Right pan: 3 : 5.',
    lp:'n : 20', rp:'3 : 5',
    q:'What is n? This is the final seal of the tower.',
    ca:'12',
    exp:'✓  5 × 4 = 20, so multiply 3 × 4 = 12. n = 12. The Grand Scale glows — the tower is yours.'
  }
];

const TOTAL = Qs.length;
let cur=0, wrongAttempts=0, totalWrong=0, answered=false, transDone=false, shapeDone=false, levelDone=false;

function num(s) { const m=String(s).trim().match(/\d+/); return m?m[0]:String(s).trim().toLowerCase(); }

function scaleEl() { return document.getElementById('scale-el'); }
function scaleState(st) {
  const el=scaleEl(); if(!el) return;
  el.classList.remove('scale-balanced','scale-wrong');
  if(st==='balanced') el.classList.add('scale-balanced');
  else if(st==='wrong') { el.classList.add('scale-wrong'); setTimeout(()=>el&&el.classList.remove('scale-wrong'),600); }
}
function scaleHTML(lp,rp) {
  return `<div class="scale-wrap" id="scale-el">
    <div class="beam-outer"><div class="beam"></div></div>
    <div class="pillar"><div class="post"></div><div class="base"></div></div>
    <div class="sc-side sc-side-l"><div class="chain"></div><div class="pan"><div class="pan-expr">${lp}</div></div></div>
    <div class="sc-side sc-side-r"><div class="chain"></div><div class="pan"><div class="pan-expr">${rp}</div></div></div>
  </div>`;
}

function renderTitle() {
  document.getElementById('gc').innerHTML=`
    <div class="title-scr screen">
      <p class="t-eyebrow">A missing-value adventure</p>
      <span class="t-icon">⚗️</span>
      <h1 class="t-main">The Alchemist's Scale</h1>
      <p class="t-tag">Balance the Unknown</p>
      <p class="t-intro">Deep in a jungle tower, an ancient alchemist left twenty-three floors of unsolved scales. Each one hides a missing value. Make each scale balance and the next floor unlocks — all the way to the Grand Atelier at the top.</p>
      <button class="start-btn" onclick="startGame()">Climb the Tower</button>
    </div>`;
}

function renderTransitionA() {
  transDone=true;
  document.getElementById('gc').innerHTML=`
    <div class="trans-scr screen">
      <h2 class="trans-headline">The Alchemist Appears</h2>
      <p class="trans-body">The alchemist steps from the shadows, studying you with bright eyes.<br><br>"You have mastered the mystery box," they say. "Every time you solved one of those scales, the box held a number — a value waiting to be found. Mathematicians have a proper name for this. They call it a <em>variable</em>."<br><br>They write a single letter in the air with a glowing finger. It hangs there, shimmering.</p>
      <div class="symbol-row">
        <div class="sym-box"><span class="sym-char is-box">□</span><span class="sym-desc">mystery box</span></div>
        <span class="sym-arrow">→</span>
        <div class="sym-box"><span class="sym-char is-n">n</span><span class="sym-desc">variable</span></div>
      </div>
      <p class="trans-body" style="margin-bottom:20px">"Same idea — a number you don't know yet, but can find by keeping the scale balanced. From here, the scales will use <em>n</em>."</p>
      <button class="understand-btn" onclick="renderQuestion()">I understand — show me n</button>
    </div>`;
}

function renderShapeIntro() {
  shapeDone=true;
  document.getElementById('gc').innerHTML=`
    <div class="trans-scr screen">
      <h2 class="trans-headline">The Cipher Gallery</h2>
      <p class="trans-body">The alchemist pauses on the stairs and turns to face you.<br><br>"Before we go further, I want to show you something. The scales on the next floors use <em>shapes</em> instead of letters — circles and squares, each with a hidden weight."<br><br>"It works exactly the same way. If you know what the square weighs, you can subtract it from the total. Whatever is left belongs to the circles — then you just divide."</p>
      <div class="symbol-row" style="gap:40px">
        <div class="sym-box"><span style="font-size:2.2rem;display:block;margin-bottom:6px">🔵</span><span class="sym-desc">unknown weight</span></div>
        <div class="sym-box"><span style="font-size:2.2rem;display:block;margin-bottom:6px">🟧</span><span class="sym-desc">known weight</span></div>
      </div>
      <p class="trans-body" style="margin-bottom:20px">"Subtract the squares. Divide among the circles. That's it."</p>
      <button class="understand-btn" onclick="renderQuestion()">Got it — show me the shapes</button>
    </div>`;
}

function renderLevelUp() {
  levelDone=true;
  document.getElementById('gc').innerHTML=`
    <div class="level-scr screen">
      <span class="level-icon">🔓</span>
      <h2 class="level-headline">Shapes → Letters</h2>
      <p class="level-body">"You see it now," the alchemist says quietly. "Every shape puzzle you just solved — those were two-step equations. You were subtracting first, then dividing. The circles were n all along."<br><br>They write on the wall beside you:</p>
      <div class="level-eg">
        <span style="color:rgba(94,206,202,.7)">Shape version:</span>&nbsp; 3🔵 + 2🟧 = 27 &nbsp;(🟧 = 3)<br>
        <span style="color:rgba(94,206,202,.7)">Algebra version:</span>&nbsp; 3×n + 6 = 27<br>
        Step 1 → 27 − 6 = 21 &nbsp;→&nbsp; Step 2 → 21 ÷ 3 = <span class="hi">7</span> &nbsp;→&nbsp; <span class="hi">n = 7 ✓</span>
      </div>
      <button class="ready-btn" onclick="renderQuestion()">I see it — open the next doors</button>
    </div>`;
}

function renderQuestion() {
  const q=Qs[cur];
  const pct=(cur/TOTAL)*100;
  const letters=['A','B','C','D'];
  const ansBlock = q.type==='typed'
    ? `<div class="type-badge">Type your answer</div>
       <div class="typed-row">
         <input class="typed-in" id="ti" type="text" placeholder="Type your answer…" autocomplete="off" autocorrect="off" spellcheck="false"/>
         <button class="sub-btn" id="sb" onclick="checkTyped()">Submit</button>
       </div>
       <p class="typed-hint">Just the number is fine</p>`
    : `<div class="answers">${q.ans.map((a,i)=>`<button class="ans-btn" onclick="checkAns(${i})" id="ab${i}"><span class="ans-ltr">${letters[i]}</span>${a}</button>`).join('')}</div>`;

  document.getElementById('gc').innerHTML=`
    <div class="screen">
      <div class="progress-wrap">
        <span class="prog-label">Progress</span>
        <div class="prog-track"><div class="prog-fill" style="width:${pct}%"></div></div>
        <span class="prog-count">${cur+1} / ${TOTAL}</span>
      </div>
      <div class="chamber-hdr">
        <p class="floor-lbl">${q.floor}</p>
        <h2 class="chamber-name">${q.name}</h2>
      </div>
      <div class="dvdr"><div class="dvdr-line"></div><div class="dvdr-dia"></div><div class="dvdr-line"></div></div>
      <p class="story">${q.story}</p>
      ${scaleHTML(q.lp,q.rp)}
      <p class="question-txt">${q.q}</p>
      ${ansBlock}
      <div class="feedback" id="fb"></div>
      <button class="cont-btn" id="cb" onclick="nextQ()">Continue →</button>
    </div>`;

  answered=false;
  if(q.type==='typed') {
    const ti=document.getElementById('ti');
    ti.addEventListener('keydown',e=>{ if(e.key==='Enter') checkTyped(); });
    ti.focus();
  }
}

function checkAns(idx) {
  if(answered) return;
  const q=Qs[cur];
  const fb=document.getElementById('fb'), cb=document.getElementById('cb');
  const btns=document.querySelectorAll('.ans-btn');
  btns.forEach(b=>b.disabled=true);
  if(idx===q.cor) {
    answered=true; btns[idx].classList.add('correct');
    fb.textContent=q.exp; fb.className='feedback ok-msg';
    cb.classList.add('show'); scaleState('balanced');
  } else {
    totalWrong++; wrongAttempts++; btns[idx].classList.add('wrong');
    const hints=['Not quite — what value makes both sides equal?','Almost! Try subtracting the known weight first, then divide.','Keep going — deal with the squares first, then the circles.'];
    fb.textContent=hints[Math.min(wrongAttempts-1,hints.length-1)]; fb.className='feedback bad-msg';
    scaleState('wrong');
    setTimeout(()=>btns.forEach((b,i)=>{ if(i!==idx) b.disabled=false; }),660);
  }
}

function checkTyped() {
  if(answered) return;
  const q=Qs[cur];
  const ti=document.getElementById('ti'), sb=document.getElementById('sb');
  const fb=document.getElementById('fb'), cb=document.getElementById('cb');
  const raw=ti.value.trim(); if(!raw) return;
  if(num(raw)===num(q.ca)) {
    answered=true; ti.disabled=true; sb.disabled=true; ti.classList.add('ok');
    fb.textContent=q.exp; fb.className='feedback ok-msg';
    cb.classList.add('show'); scaleState('balanced');
  } else {
    totalWrong++; wrongAttempts++; ti.classList.add('bad'); ti.value='';
    const hints=['Not quite — just type the number. Subtract the squares first.','Try again. Multiply the square weight by how many there are, then subtract.','So close! Check your division — subtract first, then divide among the circles.'];
    fb.textContent=hints[Math.min(wrongAttempts-1,hints.length-1)]; fb.className='feedback bad-msg';
    scaleState('wrong');
    setTimeout(()=>{ ti.classList.remove('bad'); ti.focus(); },500);
  }
}

function nextQ() {
  cur++; wrongAttempts=0;
  if(cur===7  && !transDone)  { renderTransitionA(); return; }
  if(cur===13 && !shapeDone)  { renderShapeIntro();  return; }
  if(cur===18 && !levelDone)  { renderLevelUp();     return; }
  if(cur>=TOTAL) { renderWin(); return; }
  renderQuestion();
}

function startGame() {
  cur=0; totalWrong=0; wrongAttempts=0; answered=false; transDone=false; shapeDone=false; levelDone=false;
  renderQuestion();
}

function renderWin() {
  const badge = totalWrong===0 ? 'Flawless — a true Master Alchemist! 🏆'
    : totalWrong<=6 ? 'Excellent Apprentice! ⭐' : 'Well done — the tower is balanced. 🌟';
  document.getElementById('gc').innerHTML=`
    <div class="win-scr screen">
      <span class="win-icon">🔮</span>
      <h2 class="win-title">The Tower is Balanced!</h2>
      <p class="win-text">You solved every scale in the alchemist's tower — from the first mystery box on the ground floor, through the Cipher Gallery, all the way to the Grand Atelier at the summit of Floor Twenty-Three. The alchemist's entire collection of notes is yours.</p>
      <div class="win-stats">
        <div class="stat"><span class="stat-n">23</span><span class="stat-l">Scales Balanced</span></div>
        <div class="stat"><span class="stat-n">${totalWrong}</span><span class="stat-l">Wrong Attempts</span></div>
      </div>
      <p class="win-badge">${badge}</p>
      <button class="again-btn" onclick="renderTitle()">Play Again</button>
    </div>`;
}

renderTitle();
</script>
</body>
</html>
