<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The Alchemist's Scale</title>
<link href="https://fonts.googleapis.com/css2?family=Raleway:ital,wght@0,600;0,700;0,800;0,900;1,700&family=Nunito:ital,wght@0,400;0,600;0,700;1,400;1,600&display=swap" rel="stylesheet">
<style>
:root {
  --jungle:      #1a2e1a;
  --moss:        #2d4a1e;
  --stone:       #2a2318;
  --stone-mid:   #3d3224;
  --stone-lt:    #544535;
  --copper:      #c47a3a;
  --copper-dk:   #8a4e1e;
  --copper-lt:   #dfa060;
  --gold:        #c9a84c;
  --gold-lt:     #e8c97a;
  --teal:        #5ececa;
  --teal-dk:     #3aa6a0;
  --parch:       #f5e6c8;
  --parch-dim:   rgba(245,230,200,0.72);
  --red:         #c0392b;
  --green-ok:    #4ecb71;
}
*,*::before,*::after { margin:0; padding:0; box-sizing:border-box; }

body {
  font-family: 'Nunito', sans-serif;
  background: var(--jungle);
  color: var(--parch);
  min-height: 100vh;
  display: flex; align-items: center; justify-content: center;
  position: relative; overflow: hidden;
}
body::before {
  content:''; position:fixed; inset:0;
  background:
    radial-gradient(ellipse at 15% 15%, rgba(45,74,30,.65) 0%, transparent 50%),
    radial-gradient(ellipse at 85% 85%, rgba(26,46,26,.80) 0%, transparent 50%),
    radial-gradient(ellipse at 50% 50%, rgba(42,35,24,.35) 0%, transparent 70%);
  pointer-events:none; z-index:0;
}
.firefly {
  position:fixed; width:3px; height:3px; border-radius:50%;
  background:rgba(232,201,122,.75); box-shadow:0 0 5px rgba(232,201,122,.7);
  animation:drift linear infinite; pointer-events:none; z-index:0;
}
@keyframes drift {
  0%   { transform:translate(0,0) scale(1); opacity:0; }
  10%  { opacity:1; }
  50%  { transform:translate(var(--dx),var(--dy)) scale(1.4); opacity:.8; }
  90%  { opacity:.4; }
  100% { transform:translate(calc(var(--dx)*2),calc(var(--dy)*2)) scale(.8); opacity:0; }
}
.glow-top {
  position:fixed; top:-100px; left:50%; transform:translateX(-50%);
  width:550px; height:280px;
  background:radial-gradient(ellipse, rgba(196,122,58,.1) 0%, transparent 70%);
  pointer-events:none; z-index:0;
}
.game-wrap { position:relative; z-index:10; width:min(640px,96vw); display:flex; flex-direction:column; }
.attribution { text-align:center; font-family:'Raleway',sans-serif; font-size:.58rem; letter-spacing:.35em; color:rgba(201,168,76,.5); text-transform:uppercase; margin-bottom:7px; }

.card {
  background:linear-gradient(145deg, rgba(84,69,53,.96) 0%, rgba(61,50,36,.98) 40%, rgba(42,35,24,1) 100%);
  border:1.5px solid rgba(201,168,76,.25); border-radius:5px;
  padding:30px 36px 36px;
  box-shadow:0 0 0 1px rgba(201,168,76,.08), 0 8px 45px rgba(0,0,0,.75), inset 0 1px 0 rgba(201,168,76,.09), inset 0 -1px 0 rgba(0,0,0,.3);
  position:relative; overflow:hidden;
}
.card::before { content:''; position:absolute; top:0; left:0; right:0; height:1px; background:linear-gradient(90deg,transparent,rgba(201,168,76,.3),transparent); }
.card::after {
  content:''; position:absolute; inset:0;
  background-image:
    repeating-linear-gradient(87deg,transparent,transparent 65px,rgba(0,0,0,.025) 65px,rgba(0,0,0,.025) 66px),
    repeating-linear-gradient(3deg,transparent,transparent 80px,rgba(0,0,0,.018) 80px,rgba(0,0,0,.018) 81px);
  pointer-events:none;
}

.progress-wrap { display:flex; align-items:center; gap:12px; margin-bottom:22px; }
.prog-label { font-family:'Raleway',sans-serif; font-size:.68rem; letter-spacing:.18em; color:rgba(201,168,76,.45); text-transform:uppercase; white-space:nowrap; }
.prog-track { flex:1; height:4px; background:rgba(0,0,0,.4); border-radius:2px; border:1px solid rgba(201,168,76,.07); }
.prog-fill { height:100%; background:linear-gradient(90deg,var(--copper-dk),var(--copper),var(--copper-lt)); border-radius:2px; transition:width .65s ease; box-shadow:0 0 6px var(--copper-dk); }
.prog-count { font-family:'Raleway',sans-serif; font-size:.68rem; letter-spacing:.08em; color:rgba(201,168,76,.45); white-space:nowrap; }

.chamber-hdr { text-align:center; margin-bottom:16px; }
.floor-lbl { font-family:'Raleway',sans-serif; font-size:.68rem; letter-spacing:.3em; color:rgba(201,168,76,.42); text-transform:uppercase; margin-bottom:5px; }
.chamber-name { font-family:'Raleway',sans-serif; font-size:1.6rem; font-weight:800; color:var(--copper-lt); text-shadow:0 0 20px rgba(196,122,58,.28); line-height:1.2; }

.dvdr { display:flex; align-items:center; gap:10px; margin:13px 0; }
.dvdr-line { flex:1; height:1px; background:linear-gradient(90deg,transparent,rgba(201,168,76,.18),transparent); }
.dvdr-dia { width:5px; height:5px; background:rgba(201,168,76,.45); transform:rotate(45deg); }

.story { font-style:italic; font-size:1.08rem; line-height:1.8; color:var(--parch-dim); margin-bottom:16px; padding:13px 17px; background:rgba(0,0,0,.22); border-left:2px solid rgba(201,168,76,.2); border-radius:0 3px 3px 0; }

/* ── SCALE ── */
.scale-wrap { position:relative; width:320px; height:185px; margin:0 auto 16px; }
.beam-outer { position:absolute; top:38px; left:50%; width:240px; height:9px; transform:translateX(-50%); }
.beam { width:100%; height:100%; background:linear-gradient(90deg,var(--copper-dk),var(--copper-lt),var(--copper-dk)); border-radius:5px; transform:rotate(10deg); transform-origin:center center; transition:transform .85s cubic-bezier(.34,1.56,.64,1); position:relative; }
.beam::after { content:''; position:absolute; top:50%; left:50%; transform:translate(-50%,-50%) rotate(45deg); width:11px; height:11px; background:var(--gold-lt); box-shadow:0 0 8px var(--gold); }
.pillar { position:absolute; top:47px; left:50%; transform:translateX(-50%); display:flex; flex-direction:column; align-items:center; pointer-events:none; }
.post { width:7px; height:78px; background:linear-gradient(90deg,var(--copper-dk),var(--copper-lt),var(--copper-dk)); border-radius:2px; }
.base { width:120px; height:13px; background:linear-gradient(90deg,var(--copper-dk),var(--copper),var(--copper-dk)); border-radius:7px; box-shadow:0 4px 10px rgba(0,0,0,.5); }
.sc-side { position:absolute; top:47px; display:flex; flex-direction:column; align-items:center; transition:transform .85s cubic-bezier(.34,1.56,.64,1); }
.sc-side-l { left:0;  transform:translateY(-22px); }
.sc-side-r { right:0; transform:translateY(22px); }
.chain { width:2px; height:34px; background:linear-gradient(180deg,var(--copper-dk),rgba(196,122,58,.2)); }
.pan { width:106px; min-height:52px; background:rgba(26,30,20,.85); border:1.5px solid rgba(201,168,76,.2); border-radius:5px 5px 22px 22px; display:flex; align-items:center; justify-content:center; padding:10px 7px; transition:border-color .4s, box-shadow .4s; }
.pan-expr { font-family:'Raleway',sans-serif; font-size:1.12rem; font-weight:700; color:var(--parch); letter-spacing:.04em; text-align:center; line-height:1.3; }

.scale-balanced .beam { transform:rotate(0deg); }
.scale-balanced .sc-side-l, .scale-balanced .sc-side-r { transform:translateY(0); }
.scale-balanced .pan { border-color:rgba(94,206,202,.55); box-shadow:0 0 14px rgba(94,206,202,.2); }
.scale-balanced .pan-expr { color:var(--teal); }
.scale-wrong .beam { animation:beamShake .55s ease forwards; }
@keyframes beamShake { 0%{transform:rotate(10deg)} 20%{transform:rotate(24deg)} 40%{transform:rotate(4deg)} 60%{transform:rotate(19deg)} 80%{transform:rotate(8deg)} 100%{transform:rotate(10deg)} }

/* ── ANSWERS ── */
.question-txt { font-size:1.22rem; font-weight:600; color:var(--parch); line-height:1.65; margin-bottom:18px; }
.answers { display:grid; grid-template-columns:1fr 1fr; gap:9px; margin-bottom:6px; }
.ans-btn { font-family:'Nunito',sans-serif; font-size:1.12rem; font-weight:600; padding:13px 14px; background:rgba(0,0,0,.22); border:1.5px solid rgba(201,168,76,.16); border-radius:3px; color:var(--parch); cursor:pointer; transition:all .17s ease; display:flex; align-items:center; gap:10px; text-align:left; }
.ans-btn:hover:not(:disabled) { background:rgba(201,168,76,.1); border-color:rgba(201,168,76,.38); transform:translateY(-1px); }
.ans-ltr { font-family:'Raleway',sans-serif; font-size:.72rem; color:rgba(201,168,76,.5); width:18px; flex-shrink:0; }
.ans-btn.correct { background:rgba(78,203,113,.15); border-color:var(--green-ok); color:#b0f4c8; animation:popIn .38s ease; }
.ans-btn.wrong   { background:rgba(192,57,43,.12);  border-color:var(--red); color:rgba(245,230,200,.35); animation:jiggle .35s ease; }
.ans-btn:disabled { cursor:default; }
@keyframes popIn  { 0%{transform:scale(1)} 50%{transform:scale(1.03)} 100%{transform:scale(1)} }
@keyframes jiggle { 0%,100%{transform:translateX(0)} 25%{transform:translateX(-5px)} 75%{transform:translateX(5px)} }

.type-badge { display:inline-block; font-family:'Raleway',sans-serif; font-size:.65rem; letter-spacing:.2em; text-transform:uppercase; padding:3px 10px; margin-bottom:10px; border:1px solid rgba(94,206,202,.28); border-radius:2px; color:rgba(94,206,202,.6); background:rgba(94,206,202,.05); }
.typed-row { display:flex; gap:9px; margin-bottom:6px; }
.typed-in { flex:1; font-family:'Raleway',sans-serif; font-size:1.25rem; font-weight:700; letter-spacing:.04em; padding:13px 16px; background:rgba(0,0,0,.28); border:1.5px solid rgba(201,168,76,.2); border-radius:3px; color:var(--parch); outline:none; transition:border-color .2s, box-shadow .2s; }
.typed-in::placeholder { color:rgba(245,230,200,.2); font-style:italic; font-weight:400; }
.typed-in:focus { border-color:rgba(201,168,76,.52); box-shadow:0 0 0 2px rgba(201,168,76,.1); }
.typed-in.ok  { border-color:var(--teal); background:rgba(94,206,202,.09); color:var(--teal); }
.typed-in.bad { border-color:var(--red); animation:jiggle .35s ease; }
.sub-btn { font-family:'Raleway',sans-serif; font-size:.72rem; letter-spacing:.15em; text-transform:uppercase; padding:13px 18px; background:rgba(201,168,76,.1); border:1.5px solid rgba(201,168,76,.24); border-radius:3px; color:var(--gold-lt); cursor:pointer; transition:all .17s ease; white-space:nowrap; }
.sub-btn:hover:not(:disabled) { background:rgba(201,168,76,.2); border-color:var(--gold); }
.sub-btn:disabled { opacity:.45; cursor:default; }
.typed-hint { font-family:'Raleway',sans-serif; font-size:.65rem; letter-spacing:.1em; color:rgba(201,168,76,.3); text-align:center; margin-top:5px; }

.feedback { min-height:26px; text-align:center; font-size:1.05rem; line-height:1.55; margin-top:12px; }
.feedback.ok-msg  { color:#b0f4c8; }
.feedback.bad-msg { color:#f0acac; }

.cont-btn { display:none; margin:14px auto 0; font-family:'Raleway',sans-serif; font-size:.75rem; letter-spacing:.2em; text-transform:uppercase; padding:13px 30px; background:linear-gradient(135deg,var(--copper-dk),var(--copper)); border:none; border-radius:3px; color:var(--stone); cursor:pointer; font-weight:700; box-shadow:0 4px 14px rgba(138,78,30,.4); transition:all .2s ease; }
.cont-btn:hover { background:linear-gradient(135deg,var(--copper),var(--copper-lt)); transform:translateY(-1px); }
.cont-btn.show { display:block; }

.screen { animation:fadeUp .42s ease; }
@keyframes fadeUp { from{opacity:0;transform:translateY(7px)} to{opacity:1;transform:translateY(0)} }

.title-scr { text-align:center; padding:6px 0; }
.t-eyebrow { font-family:'Raleway',sans-serif; font-size:.7rem; letter-spacing:.38em; color:rgba(201,168,76,.45); text-transform:uppercase; margin-bottom:13px; }
.t-icon { font-size:3.1rem; display:block; margin-bottom:14px; filter:drop-shadow(0 0 12px rgba(201,168,76,.4)); }
.t-main { font-family:'Raleway',sans-serif; font-size:2.4rem; font-weight:900; color:var(--copper-lt); text-shadow:0 0 28px rgba(196,122,58,.3); margin-bottom:5px; line-height:1.1; }
.t-tag  { font-family:'Raleway',sans-serif; font-size:.95rem; letter-spacing:.15em; color:rgba(201,168,76,.45); margin-bottom:22px; }
.t-intro { font-size:1.1rem; line-height:1.8; color:var(--parch-dim); max-width:420px; margin:0 auto 26px; }
.start-btn { font-family:'Raleway',sans-serif; font-size:.82rem; letter-spacing:.22em; text-transform:uppercase; padding:15px 42px; background:linear-gradient(135deg,var(--copper-dk),var(--copper),var(--copper-lt)); border:none; border-radius:3px; color:var(--stone); cursor:pointer; font-weight:700; box-shadow:0 6px 20px rgba(138,78,30,.5); transition:all .25s ease; }
.start-btn:hover { transform:translateY(-2px); box-shadow:0 10px 26px rgba(138,78,30,.65); }

/* ── TRANSITION A ── */
.trans-scr { text-align:center; padding:4px 0; }
.trans-headline { font-family:'Raleway',sans-serif; font-size:1.5rem; font-weight:800; color:var(--copper-lt); margin-bottom:13px; }
.trans-body { font-size:1.08rem; line-height:1.82; color:var(--parch-dim); text-align:left; margin-bottom:18px; }
.symbol-row { display:flex; align-items:center; justify-content:center; gap:28px; margin:0 0 20px; padding:18px; background:rgba(0,0,0,.22); border-radius:3px; border:1px solid rgba(201,168,76,.12); }
.sym-box { text-align:center; }
.sym-char { font-family:'Raleway',sans-serif; font-size:2.8rem; font-weight:900; display:block; line-height:1; margin-bottom:6px; }
.sym-char.is-box { color:var(--parch); }
.sym-char.is-n   { color:var(--teal); text-shadow:0 0 16px rgba(94,206,202,.5); }
.sym-desc { font-family:'Raleway',sans-serif; font-size:.68rem; letter-spacing:.15em; text-transform:uppercase; color:rgba(201,168,76,.4); }
.sym-arrow { font-size:1.6rem; color:rgba(201,168,76,.4); }
.understand-btn { font-family:'Raleway',sans-serif; font-size:.75rem; letter-spacing:.18em; text-transform:uppercase; padding:13px 32px; background:linear-gradient(135deg,var(--teal-dk),var(--teal)); border:none; border-radius:3px; color:var(--stone); cursor:pointer; font-weight:700; box-shadow:0 4px 14px rgba(58,166,160,.4); transition:all .2s ease; }
.understand-btn:hover { transform:translateY(-1px); box-shadow:0 6px 18px rgba(58,166,160,.58); }

/* ── TRANSITION B ── */
.level-scr { text-align:center; padding:4px 0; }
.level-icon { font-size:2.6rem; display:block; margin-bottom:12px; }
.level-headline { font-family:'Raleway',sans-serif; font-size:1.45rem; font-weight:800; color:var(--copper-lt); margin-bottom:12px; }
.level-body { font-size:1.08rem; line-height:1.82; color:var(--parch-dim); text-align:left; margin-bottom:18px; }
.level-eg { font-family:'Raleway',sans-serif; font-size:1.08rem; font-weight:600; text-align:center; color:var(--parch); padding:16px; margin-bottom:20px; background:rgba(0,0,0,.22); border-radius:3px; border:1px solid rgba(201,168,76,.12); line-height:2.2; }
.level-eg .hi { color:var(--teal); }
.ready-btn { font-family:'Raleway',sans-serif; font-size:.75rem; letter-spacing:.18em; text-transform:uppercase; padding:13px 32px; background:linear-gradient(135deg,var(--copper-dk),var(--copper)); border:none; border-radius:3px; color:var(--stone); cursor:pointer; font-weight:700; box-shadow:0 4px 14px rgba(138,78,30,.4); transition:all .2s ease; }
.ready-btn:hover { transform:translateY(-1px); }

/* ── WIN ── */
.win-scr { text-align:center; padding:6px 0; }
.win-icon { font-size:3.2rem; display:block; margin-bottom:12px; animation:float 2s ease-in-out infinite; }
@keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-8px)} }
.win-title { font-family:'Raleway',sans-serif; font-size:2rem; font-weight:900; color:var(--copper-lt); text-shadow:0 0 24px rgba(196,122,58,.38); margin-bottom:11px; }
.win-text  { font-size:1.08rem; line-height:1.78; color:var(--parch-dim); max-width:420px; margin:0 auto 20px; }
.win-stats { display:flex; justify-content:center; gap:48px; margin-bottom:20px; }
.stat { text-align:center; }
.stat-n { font-family:'Raleway',sans-serif; font-size:2.1rem; font-weight:900; color:var(--copper); display:block; line-height:1; }
.stat-l { font-size:.85rem; color:rgba(201,168,76,.45); letter-spacing:.05em; display:block; margin-top:4px; }
.win-badge { font-family:'Raleway',sans-serif; font-size:.85rem; color:var(--gold-lt); letter-spacing:.1em; margin-bottom:20px; }
.again-btn { font-family:'Raleway',sans-serif; font-size:.75rem; letter-spacing:.18em; text-transform:uppercase; padding:13px 34px; background:linear-gradient(135deg,var(--copper-dk),var(--copper)); border:none; border-radius:3px; color:var(--stone); cursor:pointer; font-weight:700; box-shadow:0 4px 14px rgba(138,78,30,.4); transition:all .2s ease; }
.again-btn:hover { transform:translateY(-1px); }

@media (max-width:480px) {
  .card { padding:20px 16px 24px; }
  .t-main { font-size:1.8rem; }
  .answers { grid-template-columns:1fr; }
  .scale-wrap { width:290px; }
  .win-stats { gap:26px; }
}
</style>
</head>
<body>

<div class="firefly" style="left:8%;top:20%;--dx:30px;--dy:-40px;animation-duration:9s;animation-delay:0s;"></div>
<div class="firefly" style="left:18%;top:65%;--dx:-20px;--dy:-30px;animation-duration:13s;animation-delay:2s;"></div>
<div class="firefly" style="left:35%;top:10%;--dx:25px;--dy:35px;animation-duration:11s;animation-delay:5s;"></div>
<div class="firefly" style="left:60%;top:80%;--dx:-35px;--dy:-25px;animation-duration:14s;animation-delay:1s;"></div>
<div class="firefly" style="left:75%;top:30%;--dx:20px;--dy:28px;animation-duration:10s;animation-delay:7s;"></div>
<div class="firefly" style="left:88%;top:55%;--dx:-22px;--dy:-18px;animation-duration:12s;animation-delay:3s;"></div>
<div class="firefly" style="left:45%;top:45%;--dx:18px;--dy:-32px;animation-duration:16s;animation-delay:4s;"></div>
<div class="glow-top"></div>

<div class="game-wrap">
  <p class="attribution">✦ Mind the Gap Tutoring ✦</p>
  <div class="card"><div id="gc"></div></div>
</div>

<script>
const Qs = [
  // ── 1 MC □  □+□=10
  { type:'mc', floor:'Floor One', name:'The Weighing Room',
    story:'You push open the iron door of the alchemist\'s tower and step inside. The ground floor is The Weighing Room — a copper balance scale dominates the centre, its beam creaking softly. A note reads: "The scale must balance before you may climb higher."',
    lp:'□ + □', rp:'10',
    q:'Both pans hold the same mystery value — □. What must □ be so the pans total 10?',
    ans:['3','4','5','6'], cor:2,
    exp:'✓  □ + □ = 10, so □ = 5. The beam settles perfectly — the staircase clicks open!'
  },
  // ── 2 MC □  3×□=12
  { type:'mc', floor:'Floor Two', name:'The Reagent Store',
    story:'Hundreds of glass bottles line the shelves, each filled with shimmering liquid. A recipe carved in the wall reads: "Three equal measures of Moonwater balance exactly 12 grams on the Grand Scale."',
    lp:'3 × □', rp:'12',
    q:'Each measure of Moonwater has the same weight — □. What is □?',
    ans:['2','3','4','6'], cor:2,
    exp:'✓  12 ÷ 3 = 4. Each measure weighs 4. You pour carefully — the scale rests level.'
  },
  // ── 3 MC □  □×4=20
  { type:'mc', floor:'Floor Three', name:'The Crystal Vault',
    story:'Four identical crystal shards rest in the left pan, glittering ice-blue in the torchlight. A counterweight stamped with 20 sits in the right pan. The shards must balance the counterweight exactly.',
    lp:'□ × 4', rp:'20',
    q:'Each crystal shard weighs □. What is □?',
    ans:['3','4','5','8'], cor:2,
    exp:'✓  20 ÷ 4 = 5. Each shard weighs 5. The vault door swings open.'
  },
  // ── 4 MC □  2×□=18
  { type:'mc', floor:'Floor Four', name:'The Night Garden',
    story:'Pale moonflowers bloom on every shelf. Two identical bundles of dried night-herbs sit in the left pan, balanced against 18 measures. You need to know how heavy each bundle is.',
    lp:'2 × □', rp:'18',
    q:'Each bundle of night-herbs weighs □. What is □?',
    ans:['6','7','8','9'], cor:3,
    exp:'✓  18 ÷ 2 = 9. Each bundle weighs 9. The perfume of the garden follows you upward.'
  },
  // ── 5 TYPED □  □×5=35
  { type:'typed', floor:'Floor Five', name:'The Brewing Chamber',
    story:'Five identical cauldrons sit in a row, each bubbling with deep-blue potion. Together they weigh exactly 35 measures. Find the weight of a single cauldron.',
    lp:'□ × 5', rp:'35',
    q:'Each cauldron weighs □. Type the value of □ to balance the scale.',
    ca:'7',
    exp:'✓  35 ÷ 5 = 7. Each cauldron holds 7 measures. Steam rises — the door unlocks!'
  },
  // ── 6 MC □  proportion 2:□=6:9
  { type:'mc', floor:'Floor Six', name:'The River Room',
    story:'Water flows through two stone channels. The left channel runs 2 litres for every □ buckets. The right runs 6 litres for every 9 buckets. Both rates must match for the scale to balance.',
    lp:'2 : □', rp:'6 : 9',
    q:'For both rates to be equal, what must □ be?',
    ans:['2','3','4','6'], cor:1,
    exp:'✓  6 : 9 simplifies to 2 : 3, so □ = 3. The water flows in perfect balance!'
  },
